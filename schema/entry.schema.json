{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BramDo/pro-student-quantum-advantage-list/blob/main/schema/entry.schema.json",
  "title": "Pro Student Quantum Advantage List entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "id", "title", "short_title", "evidence_date",
    "summary", "scale", "quantum", "classical_baselines", "comparison",
    "official_sources", "implementation", "claim_boundary", "tags"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 8},
    "short_title": {"type": "string", "minLength": 3},
    "evidence_date": {"type": "string", "format": "date"},
    "summary": {"type": "string", "minLength": 40},
    "scale": {
      "type": "object", "additionalProperties": false,
      "required": ["qubits", "sites"],
      "properties": {
        "qubits": {"type": "integer", "minimum": 1},
        "sites": {"type": ["integer", "null"], "minimum": 1}
      }
    },
    "quantum": {
      "type": "object", "additionalProperties": false,
      "required": ["backend", "task", "workflow", "timings", "result_summary"],
      "properties": {
        "backend": {"type": "string", "minLength": 3},
        "task": {"type": "string", "minLength": 10},
        "workflow": {"type": "string", "minLength": 10},
        "result_summary": {"type": "string", "minLength": 10},
        "timings": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["seconds", "scope", "primary"],
            "properties": {
              "seconds": {"type": "number", "exclusiveMinimum": 0},
              "scope": {"type": "string", "minLength": 10},
              "primary": {"type": "boolean"}
            }
          }
        }
      }
    },
    "classical_baselines": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["method", "seconds", "scope", "status"],
        "properties": {
          "method": {"type": "string", "minLength": 3},
          "seconds": {"type": ["number", "null"], "exclusiveMinimum": 0},
          "scope": {"type": "string", "minLength": 10},
          "status": {"type": "string", "minLength": 3}
        }
      }
    },
    "comparison": {
      "type": "object", "additionalProperties": false,
      "required": ["classification", "headline", "ratio", "ratio_is_lower_bound", "scope"],
      "properties": {
        "classification": {
          "enum": ["local_time_to_answer", "local_runtime_lower_bound", "paper_aligned_local_separation", "diagnostic_only"]
        },
        "headline": {"type": "string", "minLength": 20},
        "ratio": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "ratio_is_lower_bound": {"type": "boolean"},
        "scope": {"type": "string", "minLength": 20}
      }
    },
    "official_sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["label", "url", "type"],
        "properties": {
          "label": {"type": "string", "minLength": 3},
          "url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "type": {"enum": ["paper", "tracker", "repository", "data"]}
        }
      }
    },
    "implementation": {
      "type": "object", "additionalProperties": false,
      "required": ["edukaizen_url", "github_repositories", "key_articles"],
      "properties": {
        "edukaizen_url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "github_repositories": {
          "type": "array", "items": {"type": "string", "format": "uri", "pattern": "^https://"}
        },
        "key_articles": {
          "type": "array", "items": {"type": "string", "format": "uri", "pattern": "^https://"}
        }
      }
    },
    "claim_boundary": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 20}},
    "tags": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}}
  }
}

